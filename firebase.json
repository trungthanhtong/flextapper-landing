{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "**/.*",
      "**/.*/**",
      ".git/**",
      ".github/**",
      ".firebase/**",
      ".playwright-cli/**",
      "**/node_modules/**",
      "**/*.log",
      "**/*.md"
    ],
    "cleanUrls": true,
    "trailingSlash": false,
    "redirects": [
      {
        "source": "/downloads/FlexTapper.apk",
        "destination": "https://downloads.flextapper.com/latest/FlexTapper.apk",
        "type": 302
      },
      {
        "source": "/api/releases/android/latest.json",
        "destination": "https://downloads.flextapper.com/latest/metadata.json",
        "type": 302
      },
      {
        "source": "/downloads/metadata.json",
        "destination": "/download",
        "type": 302
      }
    ],
    "headers": [
      {
        "source": "index.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      },
      {
        "source": "**/*.@(js|css)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "**/*.@(png|jpg|jpeg|gif|webp|svg|ico)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "**/*.@(webmanifest|xml|txt)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=3600"
          }
        ]
      }
    ]
  }
}
